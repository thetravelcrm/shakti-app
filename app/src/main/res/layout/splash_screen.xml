<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="#F7F7F7"

     tools:context=".Splash.ui.Splash">

    <RelativeLayout
        android:layout_above="@+id/buttonimmm"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splashbanner"

        android:layout_centerInParent="true">

        <ImageView
            android:layout_width="210dp"
            android:layout_height="210dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="@dimen/_50sdp"
              android:id="@+id/img"
            android:background="@drawable/rnd_logo" />



        <com.wang.avi.AVLoadingIndicatorView
            android:id="@+id/avi"
            android:visibility="gone"
            style="@style/AVLoadingIndicatorView"
            android:layout_width="wrap_content"
              android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="@dimen/_40sdp"
              android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            app:indicatorColor="@color/button_color"
            app:indicatorName="BallPulseIndicator"
            tools:ignore="MissingConstraints" />



    </RelativeLayout>

    <ImageView
        android:layout_width="match_parent"
        android:id="@+id/buttonimmm"
        android:visibility="gone"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerInParent="true"
        android:layout_centerVertical="true"
        android:background="@drawable/spbottom" />


<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="V: 1.1"
    android:visibility="invisible"
    android:id="@+id/version"
    android:layout_margin="@dimen/_5sdp"
    android:padding="@dimen/_5sdp"
    android:layout_alignParentBottom="true"
    android:layout_alignParentRight="true"
    android:textColor="#706E6E"
    android:textSize="@dimen/_12sdp"/>


</RelativeLayout>