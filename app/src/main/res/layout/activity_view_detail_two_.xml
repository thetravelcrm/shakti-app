    <HorizontalScrollView
        android:layout_width="match_parent"
        android:scrollbars="none"
        android:layout_marginTop="@dimen/_5sdp"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorBackground"
            android:orientation="horizontal">


            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:orientation="vertical">


                <TextView
                    android:layout_width="match_parent"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:background="@color/colorBackground"
                    android:layout_height="wrap_content"
                    android:text="@string/Status"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>




                <ListView
                    android:id="@+id/li_Status"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content" >

                </ListView>




            </LinearLayout>
            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:layout_width="wrap_content"
                android:id="@+id/li_Date"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/TV_Date"
                    android:layout_width="match_parent"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:background="@color/colorBackground"
                    android:layout_height="wrap_content"
                    android:text="@string/Date"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>


                <ListView
                    android:id="@+id/Datesub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" >
                </ListView>






            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/li_District"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/TV_District"
                    android:layout_width="match_parent"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:layout_height="wrap_content"
                    android:text="@string/District"
                    android:background="@color/colorBackground"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>



                <ListView
                    android:id="@+id/Districtsub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" >
                </ListView>







            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:layout_width="wrap_content"
                android:id="@+id/li_SiteName"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/TV_SiteName"
                    android:layout_width="match_parent"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:background="@color/colorBackground"
                    android:layout_height="wrap_content"
                    android:text="@string/Sitename"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>


                <ListView
                    android:id="@+id/SiteNamesub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" >
                </ListView>








            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:layout_width="wrap_content"
                android:id="@+id/li_MobileNo"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/TV_MobileNo"
                    android:layout_width="match_parent"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:background="@color/colorBackground"
                    android:layout_height="wrap_content"
                    android:text="@string/SiteOwnerName"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>


                <ListView
                    android:id="@+id/SiteOwnermobilenumb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" >
                </ListView>






            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:layout_width="wrap_content"
                android:id="@+id/li_Sitetype"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/TV_Sitetype"
                    android:layout_width="match_parent"
                    android:background="@color/colorBackground"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:layout_height="wrap_content"
                    android:text="@string/SiteType"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>




                <ListView
                    android:id="@+id/SiteTypesub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" >
                </ListView>







            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/TV_AgentName"
                    android:layout_width="match_parent"
                    android:background="@color/colorBackground"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:layout_height="wrap_content"
                    android:text="@string/AgentName"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>



                <ListView
                    android:id="@+id/AgentNamesub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" >
                </ListView>






            </LinearLayout>
            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical">


                <TextView
                    android:id="@+id/TV_AgentMobile"
                    android:layout_width="match_parent"
                    android:background="@color/colorBackground"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:layout_height="wrap_content"
                    android:text="@string/AgentMobileNo"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>



                <ListView
                    android:id="@+id/AgentMobileNosub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" >

                </ListView>








            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="2dp"
                android:background="@color/white"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:orientation="vertical">


                <TextView

                    android:layout_width="match_parent"
                    android:background="@color/colorBackground"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:visibility="invisible"
                    android:layout_height="wrap_content"
                    android:text="S"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:padding="@dimen/_5sdp"
                    android:textSize="@dimen/_12sdp"/>




                <ListView
                    android:id="@+id/verify"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content" >

                </ListView>




            </LinearLayout>

        </LinearLayout>


    </HorizontalScrollView>

</LinearLayout>