<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">



    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:id="@+id/main"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginRight="@dimen/_2sdp"
        android:layout_marginLeft="@dimen/_2sdp"
        android:layout_marginBottom="@dimen/_2sdp"
        android:layout_marginTop="2dp"
        android:elevation="6dp"
        card_view:cardCornerRadius="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_10sdp"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:background="@color/white"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="Date : "
                            android:singleLine="true"
                            android:textStyle="bold"
                            android:layout_gravity="left"


                            android:textColor="@color/black"
                            android:textSize="@dimen/_12sdp" />

                        <TextView
                            android:id="@+id/Date"
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="_OrderNo."
                            android:singleLine="true"
                            android:textStyle="normal"
                            android:layout_gravity="right"
                            android:textColor="@color/back_bg"
                            android:textSize="@dimen/_12sdp" />



                    </LinearLayout>



                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="District"
                            android:singleLine="true"
                            android:textStyle="bold"
                            android:layout_gravity="right"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_12sdp" />


                        <TextView
                            android:id="@+id/District"
                            android:background="@color/white"
                            android:layout_gravity="right"
                            android:layout_marginLeft="@dimen/_5sdp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OrderNo."
                            android:singleLine="true"
                            android:gravity="right"
                            android:textStyle="normal"
                            android:textColor="@color/back_bg"
                            android:textSize="@dimen/_12sdp" />



                    </LinearLayout>

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:id="@+id/linera"
                    android:background="@color/white"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="Site Name : "
                            android:singleLine="true"
                            android:textStyle="bold"
                            android:layout_gravity="left"

                            android:textColor="@color/black"
                            android:textSize="@dimen/_12sdp" />

                        <TextView
                            android:id="@+id/SiteName"
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="OrderNo."
                            android:singleLine="true"
                            android:textStyle="normal"
                            android:textColor="@color/back_bg"
                            android:textSize="@dimen/_12sdp" />


                    </LinearLayout>



                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="Mobile No "
                             android:singleLine="true"
                            android:layout_gravity="right"
                            android:textStyle="bold"


                            android:textColor="@color/black"
                            android:textSize="@dimen/_12sdp" />

                        <TextView
                            android:id="@+id/MobileNo"
                            android:background="@color/white"
                            android:layout_marginLeft="@dimen/_5sdp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OrderNo."
                            android:singleLine="true"
                            android:textStyle="normal"

                            android:textColor="@color/back_bg"
                            android:textSize="@dimen/_12sdp" />



                    </LinearLayout>

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:background="@color/white"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="Site Type : "
                            android:singleLine="true"
                            android:textStyle="bold"
                            android:layout_gravity="right"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_12sdp" />

                        <TextView
                            android:id="@+id/SiteType"
                            android:layout_gravity="left"

                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="OrderNo."
                            android:singleLine="true"
                            android:textStyle="normal"
                            android:textColor="@color/back_bg"
                            android:textSize="@dimen/_12sdp" />


                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="Agent Mobile No. : "
                            android:singleLine="true"
                            android:textStyle="bold"
                             android:layout_gravity="right"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_12sdp" />

                        <TextView
                            android:id="@+id/AgentMobileno"

                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="OrderNo."
                             android:layout_gravity="right"

                            android:singleLine="true"
                            android:textStyle="normal"
                            android:textColor="@color/back_bg"
                            android:textSize="@dimen/_12sdp" />


                    </LinearLayout>

                </RelativeLayout>


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_5sdp"
                    android:background="@color/white"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="false"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:background="@color/white"
                            android:layout_height="wrap_content"
                            android:text="Agent Name"
                            android:singleLine="true"
                            android:textStyle="bold"
                            android:layout_gravity="left"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_12sdp" />


                        <TextView
                            android:id="@+id/AgentName"
                            android:background="@color/white"
                            android:layout_marginLeft="@dimen/_5sdp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Verify_tv Verify_tv Verify_tv Verify_tv."
                            android:layout_marginRight="80dp"

                            android:singleLine="true"
                            android:layout_gravity="left"
                            android:textStyle="normal"
                            android:textColor="@color/back_bg"
                            android:textSize="@dimen/_12sdp" />



                    </LinearLayout>




 <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
     android:gravity="center"
     android:layout_centerVertical="true"
                        android:layout_alignParentRight="true"
                        android:orientation="vertical">



     <TextView
         android:layout_width="60dp"
         android:layout_height="30dp"
         android:text="Verify"
         android:id="@+id/Verify_tv"
         android:textStyle="bold"
         android:layout_alignParentRight="true"
         android:layout_gravity="center"
         android:gravity="center"
         android:background="@drawable/rectcolour"
         android:textColor="@color/green"
         android:textSize="10dp"/>


                    </LinearLayout>








                </RelativeLayout>


            </LinearLayout>




        </RelativeLayout>




    </androidx.cardview.widget.CardView>









</LinearLayout>