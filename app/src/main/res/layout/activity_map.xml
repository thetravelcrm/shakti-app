<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".Map.MapActivity">

    <include layout="@layout/toolbar"
        android:id="@+id/toolbar"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/LI_MapLayout"
        android:visibility="gone"
        android:orientation="vertical">


    <fragment xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="500dp"

        tools:context="com.example.mapwithmarker.MapsMarkerActivity" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/point"
                android:background="#FFFBDB"
                android:layout_height="wrap_content"


                android:orientation="horizontal">

                <LinearLayout
                    android:layout_weight="1"
                    android:background="#FFFBDB"
                    android:layout_width="match_parent"
                    android:paddingBottom="@dimen/_5sdp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:id="@+id/Earned_li"
                    android:padding="@dimen/_5sdp"

                    android:orientation="vertical">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="@dimen/_25sdp"
                        android:layout_marginLeft="@dimen/_10sdp"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:text="10000000"
                        android:background="@drawable/rectnn"
                        android:backgroundTint="#f26422"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:id="@+id/txt_Agent"
                        android:textSize="@dimen/_10sdp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agents"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_10sdp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_weight="1"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:background="#FFFBDB"
                    android:paddingBottom="@dimen/_5sdp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/_5sdp"
                    android:id="@+id/Redeemed_li"

                    android:orientation="vertical">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="@dimen/_25sdp"
                        android:layout_marginLeft="@dimen/_10sdp"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:text="10000000"
                        android:background="@drawable/rectnn"
                        android:backgroundTint="#018dae"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:id="@+id/txt_Dealers"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10sdp"/>

                    <TextView
                        android:background="#FFFBDB"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dealers"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_10sdp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_weight="1"
                    android:background="#FFFBDB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="@dimen/_5sdp"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:gravity="center"
                    android:padding="@dimen/_5sdp"
                    android:orientation="vertical">


                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="@dimen/_25sdp"
                        android:layout_marginLeft="@dimen/_10sdp"
                        android:layout_marginRight="@dimen/_10sdp"
                        android:text="10000000"
                        android:background="@drawable/rectnn"
                        android:backgroundTint="#af1d8a"
                        android:id="@+id/txt_Sites"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10sdp"/>

                    <TextView
                        android:layout_marginTop="@dimen/_5sdp"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sites"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_10sdp"/>


                </LinearLayout>





            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_5sdp"

                android:gravity="left"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textSize="14dp"
                    android:visibility="gone"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/black"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5dp"
                    />
                <Spinner
                    android:id="@+id/DistrictSpinner"
                    android:layout_width="match_parent"
                    android:gravity="center"
                    android:layout_height="?attr/dropdownListPreferredItemHeight"
                    android:layout_margin="10dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:ellipsize="marquee"
                    android:paddingRight="14dp"
                    android:popupBackground="@android:color/white"

                    android:dropDownWidth="300dp"
                    android:dropDownVerticalOffset="?attr/dropdownListPreferredItemHeight"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.502"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.498" />

            </LinearLayout>
        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/_50sdp"
        android:gravity="center"
        android:layout_margin="@dimen/_10sdp"
        android:id="@+id/LI_filter"
android:visibility="gone"
        android:background="@drawable/rzp_border">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14dp"
                android:textColor="@color/black"
                android:gravity="left"
                android:padding="10dp"
                android:background="@color/colorBackground"

                android:text="FILTER MAP"></TextView>
            <ImageView
                android:layout_width="@dimen/_20sdp"
                android:id="@+id/closesearch"
                android:src="@drawable/ic_baseline_close_24"
                android:padding="@dimen/_2sdp"
                android:visibility="visible"
                android:layout_centerInParent="true"
                android:layout_alignParentRight="true"
                android:layout_marginRight="@dimen/_5sdp"
                android:layout_height="@dimen/_20sdp"/>
        </RelativeLayout>
        <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_10sdp"
                android:visibility="gone"
                android:gravity="right"
                android:orientation="vertical">
        <Button
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:id="@+id/bt_search"
            android:textSize="17sp"
            android:visibility="gone"
            android:background="@drawable/roundbtn"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginLeft="@dimen/_50sdp"
            android:layout_marginRight="@dimen/_50sdp"

            android:layout_marginBottom="@dimen/_10sdp"
            android:fontFamily="sans-serif"
            android:textStyle="normal"
            android:textColor="@color/white"
            android:text="SEARCH"
            android:layout_alignParentBottom="true"/>
                <ImageView
                    android:layout_width="@dimen/_50sdp"
                    android:backgroundTint="@color/white"
                    android:src="@drawable/searchicon"
                    android:padding="@dimen/_2sdp"
                    android:visibility="gone"
                    android:layout_centerInParent="true"

                    android:layout_alignParentRight="true"


                    android:layout_height="@dimen/_50sdp"/>
            </LinearLayout>
            </RelativeLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="@dimen/_10sdp"
            android:id="@+id/LI_filterOpen"
android:visibility="gone"
            android:layout_marginBottom="@dimen/_25sdp"
            android:background="@drawable/rzp_border">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14dp"
                    android:textColor="@color/black"
                    android:gravity="left"
                    android:padding="10dp"
                    android:background="@color/colorBackground"

                    android:text="FILTER MAP"></TextView>
                <ImageView
                    android:layout_width="@dimen/_20sdp"
                    android:id="@+id/opensearch"
                    android:src="@drawable/ic_icon_filter"
                    android:padding="@dimen/_2sdp"
                    android:layout_centerInParent="true"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="@dimen/_5sdp"
                    android:layout_height="@dimen/_20sdp"/>
            </RelativeLayout>
        </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/_5sdp"
                android:layout_height="1dp"
                android:visibility="invisible"
                android:background="#D3D3D3"/>






        </LinearLayout>
    </ScrollView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/LI_ButtonLayout"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/_50sdp"
            android:textSize="@dimen/_20sdp"
            android:text="Enable Location and retry">

        </TextView>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:layout_gravity="center"
            android:id="@+id/btn_retry"
            android:text="Retry"
            >

        </Button>
    </LinearLayout>
</LinearLayout>