<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".Dashbord.ui.ViewAllActivity">

    <include layout="@layout/toolbar"
        android:id="@+id/toolbar"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:scrollbars="none"
        android:layout_marginTop="@dimen/_5sdp"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_30sdp"
                    android:orientation="horizontal">


                    <TextView
                        android:layout_width="150dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="  Date"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>
                    <TextView
                        android:layout_width="150dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="Order No"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>

                    <TextView
                        android:layout_width="190dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="Site Name"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>


                    <TextView
                        android:layout_width="170dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>


                    <TextView
                        android:layout_width="140dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="Agent Name"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>


                    <TextView
                        android:layout_width="120dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="District"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>


                    <TextView
                        android:layout_width="170dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="Quantity"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>


                    <TextView
                        android:layout_width="90dp"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:padding="@dimen/_5sdp"
                        android:textSize="@dimen/_12sdp"/>





                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:layout_height="@dimen/_2sdp"
                    android:background="@color/colorBackground"/>


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:orientation="horizontal">





                        <ListView
                            android:id="@+id/Datedealer"
                            android:layout_width="150dp"
                            android:layout_height="match_parent" >
                        </ListView>

                        <ListView
                            android:id="@+id/Ordeenodealer"
                            android:layout_width="150dp"
                            android:layout_height="match_parent" >
                        </ListView>

                        <ListView
                            android:id="@+id/SiteNamedealer"
                            android:layout_width="190dp"
                            android:layout_height="match_parent" >
                        </ListView>


                        <ListView
                            android:id="@+id/ProductNamedealer"
                            android:layout_width="170dp"
                            android:layout_height="match_parent" >
                        </ListView>




                        <ListView
                            android:id="@+id/AgentNamedealer"
                            android:layout_width="140dp"
                            android:layout_height="match_parent" >
                        </ListView>




                        <ListView
                            android:id="@+id/Districtdealer"
                            android:layout_width="120dp"
                            android:layout_height="match_parent" >
                        </ListView>


                        <ListView
                            android:id="@+id/Quantitydealer"
                            android:layout_width="170dp"
                            android:layout_height="match_parent" >

                        </ListView>


                        <ListView
                            android:id="@+id/Statusdealer"
                            android:layout_width="100dp"
                            android:layout_height="match_parent" >

                        </ListView>







                    </LinearLayout>


                </RelativeLayout>





            </LinearLayout>



        </LinearLayout>






    </HorizontalScrollView>


</LinearLayout>